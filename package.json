{
	"private": true,
	"name": "abm-kits",
	"license": "MIT",
	"version": "0.7.0",
	"scripts": {
		"preinstall": "npx -y only-allow pnpm",
		"clean": "node ./script/clean.ts",
		"prepack": "pnpm run clean && pnpm run build",
		"build:utils": "node ./script/build-utils.ts",
		"build:ui-style": "node ./script/build-css-var.ts && stylus packages/abm-ui/src/style/index.styl --include-css -o packages/abm-ui && node ./script/min-css.ts",
		"build:ui": "node ./script/build-ui.ts",
		"build:docs-theme": "tsc -p ./packages/docs-theme/tsconfig.json",
		"build:docs": "pnpm -F docs run build",
		"build": "pnpm run build:utils && pnpm run build:ui && pnpm run build:ui-style",
		"watch:utils": "node ./script/build-utils.ts -w",
		"watch:ui-style": "stylus -w packages/abm-ui/src/style/index.styl --include-css -o packages/abm-ui",
		"watch:ui": "tsc -w -p packages/abm-ui/tsconfig.json",
		"watch:docs-theme": "tsc -w -p ./packages/docs-theme/tsconfig.json",
		"watch": "concurrently \"pnpm run watch:utils\" \"pnpm run watch:ui\" \"pnpm run watch:ui-style\" \"pnpm run watch:docs-theme\"",
		"docs": "pnpm -F docs run dev",
		"dev": "pnpm -F test run dev"
	},
	"engines": {
		"node": ">=24",
		"pnpm": ">=10"
	},
	"devDependencies": {
		"@types/node": "^24",
		"concurrently": "^9.2.1",
		"esbuild": "^0.27.3",
		"lightningcss": "^1.31.1",
		"stylus": "^0.64.0",
		"typescript": "^5.9.3"
	}
}