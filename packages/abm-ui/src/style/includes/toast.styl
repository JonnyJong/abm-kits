
@keyframes ui-toast-top
	0%
		opacity 0
		translate 0 -100%

@keyframes ui-toast-right
	0%
		opacity 0
		translate 100% 0

@keyframes ui-toast-bottom
	0%
		opacity 0
		translate 0 100%

@keyframes ui-toast-left
	0%
		opacity 0
		translate -100% 0

.ui-toast-container
	position fixed
	top calc(16px + var(--offset-v, 0px) + var(--safe-top))
	right calc(16px + var(--offset-h, 0px) + var(--safe-right))
	z-index 80
	display flex
	flex-direction column
	max-width calc(100vw - 32px)
	max-height 100%
	width 400px
	gap 16px
	&[horizontal='center']
		right unset
		left calc(50vw + var(--offset-h, 0px))
		translate -50% 0
		.ui-toast
			animation ui-toast-top .3s ease-out
	&[horizontal='left']
		right unset
		left calc(16px + var(--offset-h, 0px) + var(--safe-left))
		.ui-toast
			animation-name ui-toast-left
	&[vertical='bottom']
		top unset
		bottom calc(16px + var(--offset-v, 0px) + var(--safe-bottom))
		.ui-toast
			top unset
			bottom var(--offset)
			transition .3s bottom

.ui-toast
	position absolute
	top var(--offset)
	display grid
	width 100%
	transition .3s top
	animation ui-toast-right .3s cubic-bezier(0, 1, 0, 1)
	grid-template-areas 'icon title actions' 'icon details actions'
	grid-template-columns max-content 1fr max-content
	gap 0 12px
	&[level='success']
		border-color var(--toast-border-success)
		background var(--toast-bg-success)
	&[level='warn']
		border-color var(--toast-border-warn)
		background var(--toast-bg-warn)
	&[level='error']
		border-color var(--toast-border-error)
		background var(--toast-bg-error)

.ui-toast-icon
	padding-top 2px
	font-size 16px
	grid-area icon
	&>*
		display block
		width 16px
		height 16px
		--size 16px

.ui-toast-actions
	grid-area actions

.ui-toast-title
	font-weight bold
	grid-area title

.ui-toast-details
	grid-area details