{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"target": "es2022",
		"module": "esnext",
		"moduleResolution": "bundler",
		"types": [],
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"declaration": false,
